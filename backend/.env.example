# Copy to .env and adjust as needed.

# Enable FastAPI debug mode (verbose errors, auto-reload friendly).
DEBUG=false

# Origins allowed to call the API (JSON array form, parsed by pydantic-settings).
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# sec-api.io API key, used by the Extractor API to pull Item 1A / Item 7 text
# directly out of 10-K filings. Get one at https://sec-api.io.
SEC_API_API_KEY=

# OpenAI API key, used by the LangChain chat model to decompose Item 1A into
# individual risk factors.
OPENAI_API_KEY=

# Braintrust API key, used for tracing.
BRAINTRUST_API_KEY=
